# Django environment variables (Production Template)
DEBUG=False
SECRET_KEY=generate-a-secure-random-secret-key-here
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com
DATABASE_URL=postgres://db_user:db_password@db_host:5432/db_name
REDIS_URL=redis://redis_host:6379/0
